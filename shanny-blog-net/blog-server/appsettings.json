{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Server": {
    "Port": 8080
  },
  "Swagger": {
    "UiPath": "/swagger-ui.html",
    "ApiDocsPath": "/v3/api-docs",
    "GroupName": "default",
    "MatchPath": "/**"
  },
  "SwaggerSetting": {
    "Language": "zh_cn",
    "ShowVersion": true,
    "ShowModelPreview": true
  },
  "Shanny": {
    "Jwt": {
      "UserSecretKey": "shanny-blog&https://www.shanny.work&ruanmengdashanny@gmail.com",
      "UserTtl": 86400000,
      "UserTokenName": "Authorization"
    }
  },
  "App": {
    "Name": "ShannyBlog",
    "Description": "个人博客系统",
    "Owner": "Shanny",
    "Version": "1.0.0",
    "BuildTime": "2026-06-13"
  }
}
